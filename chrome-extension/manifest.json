{
  "manifest_version": 3,
  "name": "VidRevamp — Sort & Analyze",
  "short_name": "VidRevamp",
  "version": "1.0.0",
  "description": "Sort Instagram Reels, TikTok, and YouTube Shorts by views. Find viral outliers and save hooks to your VidRevamp Vault.",

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "VidRevamp — Sort & Analyze"
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.instagram.com/*",
        "https://www.tiktok.com/*",
        "https://www.youtube.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],

  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "https://www.instagram.com/*",
    "https://www.tiktok.com/*",
    "https://www.youtube.com/*",
    "http://localhost:3001/*"
  ],

  "web_accessible_resources": [
    {
      "resources": ["icons/*.png", "content.css"],
      "matches": ["https://www.instagram.com/*", "https://www.tiktok.com/*", "https://www.youtube.com/*"]
    }
  ]
}
